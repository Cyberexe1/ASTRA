# ── Compiled output ───────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Playwright browser binaries ───────────────────────────────────────────────
playwright-browsers/

# ── Environment variables & secrets ──────────────────────────────────────────
# NEVER commit these — they contain API keys and credentials
.env
.env.local
.env.*.local
*.env
*.secret
*.key
*.pem
*.p12
*.pfx
groq-key.enc

# ── Scan output files (generated at runtime, can be large/sensitive) ──────────
report.md
capture.har
*.har
*.har.json

# ── Kiro / AI tool output ─────────────────────────────────────────────────────
graphify-out/
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json

# ── Stitch design tool exports (UI mockup exports, not source code) ───────────
stitch_*/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor directories & files ────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Test output ───────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Electron build output ─────────────────────────────────────────────────────
out/
release/
build/
*.dmg
*.exe
*.AppImage
*.snap
*.deb
*.rpm

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
*.cache
