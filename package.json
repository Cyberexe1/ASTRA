{
  "name": "astra",
  "version": "1.0.0",
  "description": "ASTRA — Automated Security Testing & Risk Analysis desktop tool",
  "main": "dist/electron/main.js",
  "bin": {
    "astra": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:electron": "tsc -p tsconfig.electron.json",
    "serve": "node dist/server.js",
    "electron": "npm run build:electron && electron .",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "electron": "^41.3.0",
    "fast-check": "^3.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
